<?xml version="1.0" encoding="UTF-8"?>
<!--
    OWASP Dependency-Check suppression file.

    Each <suppress> block silences a specific CVE against a specific
    dependency coordinate. Always document:
      1. WHY the CVE does not apply to us
      2. WHO reviewed the decision (initials / commit hash)
      3. WHEN to revisit (e.g. "when we upgrade Spring Boot to 3.6")

    Keep entries narrow — prefer matching a single coordinate, not a
    package wildcard.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Template entry (inactive — regex matches nothing).
         Copy + fill in when a real suppression is needed. -->
    <suppress>
        <notes><![CDATA[
            Example template — placeholder, not active.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/example/example@.*$</packageUrl>
        <cve>CVE-0000-00000</cve>
    </suppress>

</suppressions>
