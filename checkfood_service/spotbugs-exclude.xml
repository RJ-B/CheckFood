<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs exclude filter — noise suppression.

    Generated sources (Lombok, MapStruct, Freezed-style @Builder) produce
    false positives at a rate that drowns real findings. Everything here
    is either (a) generated, (b) a well-known non-issue in Spring/JPA
    idioms, or (c) explicitly decided-not-to-fix.
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0">

    <!-- Generated: MapStruct implementations -->
    <Match>
        <Class name="~.*Impl$" />
        <Package name="~.*\.mapper$" />
    </Match>

    <!-- Generated: Lombok @Builder / @Data classes in dto packages.
         NP_NULL_ON_SOME_PATH on optional fields is an @Builder pattern. -->
    <Match>
        <Package name="~.*\.dto\..*" />
        <Bug pattern="NP_NULL_ON_SOME_PATH" />
    </Match>

    <!-- Spring Boot main class — static SpringApplication.run is fine. -->
    <Match>
        <Class name="com.checkfood.checkfoodservice.CheckfoodServiceApplication" />
    </Match>

    <!-- JPA entities — @EntityListeners, field injection through
         reflection, mutable Date fields are idiomatic, not bugs. -->
    <Match>
        <Package name="~.*\.entity\..*" />
        <Or>
            <Bug pattern="EI_EXPOSE_REP" />
            <Bug pattern="EI_EXPOSE_REP2" />
            <Bug pattern="SE_BAD_FIELD" />
        </Or>
    </Match>

    <!-- Spring Security's BCryptPasswordEncoder + RateLimitService do
         cover the edge cases FindSecBugs flags here — documented. -->
    <Match>
        <Class name="~.*\.security\..*" />
        <Bug pattern="PREDICTABLE_RANDOM" />
    </Match>

</FindBugsFilter>
