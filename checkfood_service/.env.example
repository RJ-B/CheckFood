# ===============================================================
# LOKÁLNÍ VÝVOJ (.env.local) - ŠABLONA
# Tento soubor zkopíruj jako .env a doplň své údaje.
# ===============================================================

# Aktivuje application-local.properties (zapne logování SQL, vypne SSL kontroly atd.)
SPRING_PROFILES_ACTIVE=local

# ===============================================================
# DATABÁZE (Docker)
# ===============================================================
# Připojení na localhost, pokud je Docker port 5432 mapován na tvůj PC
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/checkfood
DB_USERNAME=your_db_user
DB_PASSWORD=your_secure_password

# ===============================================================
# SECURITY - JWT
# ===============================================================
# Minimálně 32 znaků dlouhý řetězec pro HS256
JWT_SECRET=your_super_secret_key_at_least_32_characters_long
# Platnost 15 minut (900s)
JWT_EXPIRES=900
# Refresh 30 dní (v sekundách)
JWT_REFRESH=2592000
JWT_ISSUER=checkfood-local

# ===============================================================
# EMAIL / SMTP (Např. Gmail App Password)
# ===============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_app_password_without_spaces

# ===============================================================
# APP URL (PRO MOBILNÍ VÝVOJ)
# ===============================================================
# Tvoje lokální IP adresa (např. 192.168.x.x).
# Nutné pro funkčnost odkazů v mailu při testování na reálném zařízení.
APP_BACKEND_URL=http://localhost:8081

# ===============================================================
# OSTATNÍ
# ===============================================================
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_RETENTION=30

# CORS (Povolíme frontend na localhostu i produkční doménu)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.checkfood.cz

# ===============================================================
# OAUTH (Placeholdery)
# ===============================================================
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

APPLE_CLIENT_ID=your_apple_id
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=your_private_key

# ===============================================================
# SUPABASE STORAGE (pouze pro prod profil)
# ===============================================================
SUPABASE_URL=https://ixglwaqetbbwwrxrimby.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET=checkfood-public