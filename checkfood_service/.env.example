# ===============================================================
# CheckFood Backend — SABLONA
# Zkopiruj jako .env a doplni sve udaje.
# ===============================================================

# Aktivuje application-local.properties (SQL logování, verbose debug)
SPRING_PROFILES_ACTIVE=local

# ===============================================================
# DATABAZE (Docker — docker compose up -d db)
# ===============================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/checkfood
DB_USERNAME=checkfood_admin
DB_PASSWORD=your_secure_password

# ===============================================================
# SECURITY — JWT
# ===============================================================
# Minimalne 32 znaku pro HS256
JWT_SECRET=your_super_secret_key_at_least_32_characters_long
JWT_EXPIRES=900
JWT_REFRESH=2592000
JWT_ISSUER=checkfood-local

# ===============================================================
# EMAIL / SMTP (Gmail App Password)
# ===============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your_app_password

# ===============================================================
# APP URL (pro odkazy v emailech)
# ===============================================================
# Lokalni IP pro testovani na mobilu (ipconfig -> Wi-Fi IPv4)
APP_BACKEND_URL=http://192.168.x.x:8081

# ===============================================================
# OAUTH2
# ===============================================================
# Google: Web Client ID (pro backend verifikaci ID tokenu)
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple Sign-In
APPLE_CLIENT_ID=com.checkfood.checkfood_client
APPLE_TEAM_ID=your_team_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY=your_private_key

# ===============================================================
# OSTATNI
# ===============================================================
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_RETENTION=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.checkfood.cz

# ===============================================================
# MOONE (ZNPAY) PLATEBNI BRANA
# ===============================================================
MOONE_LOGIN=your_moone_login
MOONE_PASSWORD=your_moone_password
MOONE_PAY_POINT_ID=your_pay_point_id
