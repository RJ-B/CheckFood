<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs include filter — which packages the analysis covers.
    Kept narrow to the CheckFood code base (third-party generated
    bytecode in target/ is excluded by the default plugin config).
-->
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0">
    <Match>
        <Package name="~com\.checkfood\.checkfoodservice\..*" />
    </Match>
</FindBugsFilter>
