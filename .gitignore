# ==========================================
# Root .gitignore for CHECKFOOD Project
# ==========================================

# --- Obecné systémové a dočasné soubory ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
*.log
*.swp
*.history
.env
.env.local
.env.prod
.env.test
# ==========================================
# BACKEND (checkfood-service) - IntelliJ IDEA
# ==========================================

# IDE a nástroje
checkfood-service/.idea/
checkfood-service/*.iml
checkfood-service/*.iws
checkfood-service/*.ipr
checkfood-service/.apt_generated
checkfood-service/.classpath
checkfood-service/.factorypath
checkfood-service/.project
checkfood-service/.settings/
checkfood-service/.springBeans
checkfood-service/.sts4-cache

# Build a distribuce
checkfood-service/target/
checkfood-service/build/
checkfood-service/dist/
checkfood-service/nbbuild/
checkfood-service/nbdist/
checkfood-service/.nb-gradle/
checkfood-service/nbproject/private/
checkfood-service/HELP.md
checkfood-service/.mvn/wrapper/maven-wrapper.jar

# Výjimky pro zachování struktury
!checkfood-service/src/main/**/target/
!checkfood-service/src/test/**/target/
!checkfood-service/src/main/**/build/
!checkfood-service/src/test/**/build/

# ==========================================
# CLIENT (checkfood_client) - VS Code / Flutter
# ==========================================

# IDE a systémové
checkfood_client/.vscode/
checkfood_client/.idea/
checkfood_client/*.iml
checkfood_client/*.ipr
checkfood_client/*.iws
checkfood_client/.history/

# Flutter / Dart / Pub specifika
checkfood_client/.dart_tool/
checkfood_client/.flutter-plugins
checkfood_client/.flutter-plugins-dependencies
checkfood_client/.pub-cache/
checkfood_client/.pub/
checkfood_client/.packages
checkfood_client/build/

# Web specifika
checkfood_client/web/stack.css

# Logy a dočasné soubory
checkfood_client/*.log
checkfood_client/*.mode1v3
checkfood_client/*.mode2v3
checkfood_client/*.moved-aside

# Android artefakty a lokální konfigurace
checkfood_client/android/local.properties
checkfood_client/android/**/generated/
checkfood_client/android/app/debug/
checkfood_client/android/app/profile/
checkfood_client/android/app/release/
# Ignorovat keystory (pokud je přidáš do projektu)
checkfood_client/android/*.keystore
checkfood_client/android/*.jks

# iOS / macOS specifika
checkfood_client/ios/Flutter/Generated.xcconfig
checkfood_client/ios/Flutter/flutter_export_environment.sh
checkfood_client/ios/Flutter/.last_build_id
checkfood_client/macos/Flutter/Generated.xcconfig
checkfood_client/macos/Flutter/ephemeral/
checkfood_client/**/Pods/
checkfood_client/**/.last_build_id

# Obfuskace a mapy symbolů
checkfood_client/app.*.symbols
checkfood_client/app.*.map.json