# ==========================================
# Root .gitignore — CheckFood
# ==========================================

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# --- IDE ---
.idea/
.vscode/
*.iml
*.iws
*.ipr
.history/

# --- Environment & Secrets ---
.env
.env.local
.env.prod
.env.test
!.env.example

# --- AI Agent Workflow (internal) ---
ai/

# --- Claude Code ---
.claude/
CLAUDE.md
DIPLOMKA_PROMPT.md

# --- Diplomka (private) ---
diplomka/

# --- Scripts (local) ---
scripts/

# --- Copy folder (env backups) ---
copy/

# ==========================================
# BACKEND (checkfood_service)
# ==========================================

# Build
checkfood_service/target/
checkfood_service/build/
checkfood_service/out/

# Maven wrapper JAR (script stays, jar is downloaded)
checkfood_service/.mvn/wrapper/maven-wrapper.jar

# Eclipse / IntelliJ legacy
checkfood_service/.apt_generated/
checkfood_service/.settings/
checkfood_service/.project
checkfood_service/.classpath

# Uploaded files (local storage)
checkfood_service/uploads/

# Stitcher Python
checkfood_service/stitcher/__pycache__/
checkfood_service/stitcher/.venv/
checkfood_service/stitcher/venv/
checkfood_service/stitcher/*.pyc

# ==========================================
# FRONTEND (checkfood_client)
# ==========================================

# Flutter / Dart
checkfood_client/.dart_tool/
checkfood_client/.flutter-plugins
checkfood_client/.flutter-plugins-dependencies
checkfood_client/.pub-cache/
checkfood_client/.pub/
checkfood_client/.packages
checkfood_client/build/

# Android
checkfood_client/android/local.properties
checkfood_client/android/**/generated/
checkfood_client/android/app/debug/
checkfood_client/android/app/profile/
checkfood_client/android/app/release/
checkfood_client/android/*.keystore
checkfood_client/android/*.jks

# Firebase config (contains API keys)
checkfood_client/android/app/google-services.json
checkfood_client/ios/Runner/GoogleService-Info.plist

# iOS / macOS
checkfood_client/ios/Flutter/Generated.xcconfig
checkfood_client/ios/Flutter/flutter_export_environment.sh
checkfood_client/ios/Flutter/.last_build_id
checkfood_client/macos/Flutter/Generated.xcconfig
checkfood_client/macos/Flutter/ephemeral/
checkfood_client/**/Pods/
checkfood_client/**/.last_build_id

# Symbols & obfuscation
checkfood_client/app.*.symbols
checkfood_client/app.*.map.json

# Misc
checkfood_client/*.log
checkfood_client/*.mode1v3
checkfood_client/*.mode2v3
checkfood_client/*.moved-aside
checkfood_client/web/stack.css
