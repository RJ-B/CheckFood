// ios/Flutter/Secrets.xcconfig — TEMPLATE
//
// Copy this file to `Secrets.xcconfig` (which is gitignored) and fill in
// the real values. The key propagates into Info.plist as $(MAPS_API_KEY)
// and is read by Runner/AppDelegate.swift at launch.
//
// You must also set the same value in `android/local.properties` for
// the Android build to find it.
//
// Rotate the key in Google Cloud Console when it leaks or expires,
// then update both files.

MAPS_API_KEY = YOUR_IOS_MAPS_API_KEY_HERE
