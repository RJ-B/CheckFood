<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="192dp"
    android:height="192dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Cloche dome -->
    <path android:pathData="M80,310 C80,175 165,100 256,100 C347,100 432,175 432,310 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="80"
                android:startY="100"
                android:endX="350"
                android:endY="310"
                android:startColor="#1B4F72"
                android:endColor="#0A2540" />
        </aapt:attr>
    </path>

    <!-- Knob on top -->
    <path
        android:pathData="M256,96 m-24,0 a24,20 0 1,1 48,0 a24,20 0 1,1 -48,0"
        android:fillColor="#0E3854" />

    <!-- Plate base -->
    <path android:pathData="M55,310 L457,310 L457,325 C457,333.3 450.3,340 442,340 L70,340 C61.7,340 55,333.3 55,325 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="55"
                android:startY="325"
                android:endX="457"
                android:endY="325"
                android:startColor="#0A2540"
                android:centerColor="#1B4F72"
                android:endColor="#10B981" />
        </aapt:attr>
    </path>

    <!-- Checkmark -->
    <path
        android:pathData="M168,265 L232,335 L368,185"
        android:strokeWidth="44"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="168"
                android:startY="335"
                android:endX="368"
                android:endY="185"
                android:startColor="#34D399"
                android:centerColor="#10B981"
                android:endColor="#059669" />
        </aapt:attr>
    </path>
</vector>
