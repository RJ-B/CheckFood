<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Cloche dome -->
    <path android:pathData="M80,310 C80,175 165,100 256,100 C347,100 432,175 432,310 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="80"
                android:startY="100"
                android:endX="350"
                android:endY="310"
                android:startColor="#1B4F72"
                android:endColor="#0A2540" />
        </aapt:attr>
    </path>

    <!-- Dome highlight (subtle lighter area) -->
    <path
        android:pathData="M130,280 C130,195 185,135 256,135 C300,135 340,160 365,200 C340,155 300,125 256,125 C190,125 115,190 110,290 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.08" />

    <!-- Knob on top -->
    <path android:pathData="M256,96 m-24,0 a24,20 0 1,1 48,0 a24,20 0 1,1 -48,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="248"
                android:centerY="90"
                android:gradientRadius="24"
                android:startColor="#1B4F72"
                android:endColor="#0A2540" />
        </aapt:attr>
    </path>

    <!-- Knob highlight -->
    <path
        android:pathData="M244,88 a14,10 0 1,1 16,0 a14,10 0 1,1 -16,0"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.15" />

    <!-- Rim line between dome and plate -->
    <path
        android:pathData="M65,306 L447,306 L447,310 C447,312.2 445.2,314 443,314 L69,314 C66.8,314 65,312.2 65,310 Z"
        android:fillColor="#1B4F72"
        android:fillAlpha="0.6" />

    <!-- Plate base -->
    <path android:pathData="M55,310 L457,310 L457,325 C457,333.3 450.3,340 442,340 L70,340 C61.7,340 55,333.3 55,325 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="55"
                android:startY="325"
                android:endX="457"
                android:endY="325"
                android:startColor="#0A2540"
                android:centerColor="#1B4F72"
                android:endColor="#10B981" />
        </aapt:attr>
    </path>

    <!-- Plate top highlight -->
    <path
        android:pathData="M55,310 L457,310 L457,320 C457,324.4 454.4,327 450,327 L62,327 C57.6,327 55,324.4 55,320 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.1" />

    <!-- Checkmark -->
    <path
        android:pathData="M168,265 L232,335 L368,185"
        android:strokeWidth="44"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="168"
                android:startY="335"
                android:endX="368"
                android:endY="185"
                android:startColor="#34D399"
                android:centerColor="#10B981"
                android:endColor="#059669" />
        </aapt:attr>
    </path>

    <!-- Checkmark inner highlight -->
    <path
        android:pathData="M172,260 L234,328 L364,182"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeAlpha="0.1"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />
</vector>
