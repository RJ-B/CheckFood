<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Dev-only overlay: allow cleartext HTTP so `flutter run` can talk to
         a LAN backend over http://192.168.x.x. Release builds pick up the
         stricter network_security_config.xml from src/main which forbids
         cleartext entirely. -->
    <application
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:networkSecurityConfig"
        xmlns:tools="http://schemas.android.com/tools"/>
</manifest>
