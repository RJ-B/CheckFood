# ---------------------------------------------------------------------
# CheckFood client — build-time configuration (template)
# ---------------------------------------------------------------------
#
# As of Apr 2026 the CheckFood client **no longer uses flutter_dotenv**.
# This file remains only as a reference of which keys the build expects.
# It is NOT loaded at runtime and does NOT ship in the APK/IPA.
#
# How configuration is supplied now:
#
#   1. Shell environment variables → passed to `flutter run / build`
#      by `scripts/build_dev.sh` / `scripts/build_prod.sh` via
#      `--dart-define=KEY=VALUE` → read at compile time by
#      `String.fromEnvironment(...)` in `lib/core/config/build_config.dart`.
#
#   2. Native Google Maps SDK key (separate from the Dart-side Places key):
#      • Android: `android/local.properties` → `MAPS_API_KEY=...`
#        (gradle propagates to AndroidManifest.xml via manifestPlaceholders)
#      • iOS:     `ios/Flutter/Secrets.xcconfig` → `MAPS_API_KEY = ...`
#        (xcconfig propagates to Info.plist GMSApiKey, read by AppDelegate.swift)
#
# ---------------------------------------------------------------------
# Expected keys (do NOT commit real values here):
# ---------------------------------------------------------------------

# Spring Boot backend base URL (include /api prefix)
# Dev default: http://192.168.1.199:8081/api  (LAN IP of dev laptop)
# Prod:        https://<your-cloud-run-url>/api
API_BASE_URL=

# Google OAuth "Web application" client ID (not Android/iOS type).
# Shared across backend verification and Google Sign-In SDK.
GOOGLE_WEB_CLIENT_ID=

# Apple Sign-In (defaults to app bundle identifier)
APPLE_CLIENT_ID=com.checkfood.checkfood_client
APPLE_REDIRECT_URL=

# Google Places REST API key — used by Dart-side autocomplete.
# The native MapView reads a separate key from local.properties /
# Secrets.xcconfig (see above).
GOOGLE_MAPS_API_KEY=
