# ===============================================================
# FLUTTER DART-DEFINE REFERENCE
# ===============================================================
# Tyto hodnoty se NEPOUZIVAJI primo — aplikace je cte pres --dart-define.
# Tento soubor zkopiruj jako .env a doplni sve hodnoty.
#
# Spusteni:
#   flutter run -d <device> \
#     --dart-define=API_BASE_URL=... \
#     --dart-define=GOOGLE_WEB_CLIENT_ID=... \
#     --dart-define=APPLE_CLIENT_ID=... \
#     --dart-define=APPLE_REDIRECT_URL=... \
#     --dart-define=GOOGLE_MAPS_API_KEY=...
#
# Nativni Maps SDK klic se nastavuje v android/local.properties (MAPS_API_KEY).
# ===============================================================

# --- PRODUKCE (Google Cloud Run) ---
API_BASE_URL=https://your-cloud-run-url.run.app/api
APPLE_REDIRECT_URL=https://your-cloud-run-url.run.app/api/oauth/apple/callback

# --- LOKAL (Spring Boot na lokalni siti) ---
# API_BASE_URL=http://192.168.x.x:8081/api
# APPLE_REDIRECT_URL=http://192.168.x.x:8081/api/oauth/apple/callback

# --- SPOLECNE (stejne pro lokal i produkci) ---
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.checkfood.checkfood_client
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
