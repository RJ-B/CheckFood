# --- API KONFIGURACE ---
# URL Spring Boot backendu (vaše lokální IP pro testování na mobilu)
API_BASE_URL=http://192.168.1.199:8081/api

# --- GOOGLE AUTH KONFIGURACE ---
# ID Webového klienta (Web application) - KLÍČOVÉ PRO BACKEND VERIFIKACI
# Použijte ID začínající na '809801655996-hiub...' (podle vašeho popisu .env)
GOOGLE_WEB_CLIENT_ID=809801655996-hiubgqhjj2ae8cn9872pc693evonrfvp.apps.googleusercontent.com

# --- APPLE AUTH KONFIGURACE ---
# Bundle Identifier vaší aplikace (shodný s Xcode a Apple Developer Portal)
APPLE_CLIENT_ID=com.checkfood.checkfood_client

# Callback URL pro Apple Sign-In (vyžadováno pro Android verzi Apple přihlášení)
APPLE_REDIRECT_URL=http://192.168.1.199:8081/api/oauth/apple/callback